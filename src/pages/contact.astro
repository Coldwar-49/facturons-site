---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Facturons"
  description="Contactez l'équipe Facturons pour toute question sur la facturation électronique, IOPOLE ou votre abonnement."
  canonical="/contact"
>
  <section class="py-20 px-4">
    <div class="max-w-xl mx-auto text-center mb-12">
      <h1 class="text-4xl font-extrabold text-noir mb-4">Contactez-nous</h1>
      <p class="text-gris-fonce">Réponse sous 24h ouvrées.</p>
    </div>
    <div class="max-w-xl mx-auto bg-white border border-gris rounded-2xl p-8">
      <!-- Formulaire Tally embed -->
      <iframe
        data-tally-src="https://tally.so/embed/contact-facturons"
        loading="lazy"
        width="100%"
        height="400"
        frameborder="0"
        title="Formulaire de contact Facturons"
        class="rounded-xl"
      ></iframe>
      <script async src="https://tally.so/widgets/embed.js"></script>
      <noscript>
        <p class="text-center text-gris-fonce mt-4">
          Envoyez-nous un email à
          <a href="mailto:contact@facturons.fr" class="text-bleu hover:underline font-medium">
            contact@facturons.fr
          </a>
        </p>
      </noscript>
    </div>
  </section>
</Layout>
